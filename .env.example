# ============================================
# LABOURÉ E-COMMERCE - ENVIRONMENT VARIABLES
# ============================================

# ──────────────────────────────────────────
# NODE ENVIRONMENT
# ──────────────────────────────────────────
NODE_ENV=development
# Options: development, production, test

# ──────────────────────────────────────────
# DATABASE (PostgreSQL)
# ──────────────────────────────────────────
DB_NAME=laboure_db
DB_USER=postgres
DB_PASSWORD=postgres123

# Prisma Database URL (construída automaticamente)
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/laboure_db
# ──────────────────────────────────────────
# NEXT AUTH (Authentication)
# ──────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-key-change-in-production-minimum-32-characters
NEXTAUTH_URL=http://localhost:3000

# For production, use:
# NEXTAUTH_URL=https://seudominio.com

# ──────────────────────────────────────────
# API CONFIGURATION
# ──────────────────────────────────────────
API_URL=http://localhost:3000

# For production:
# API_URL=https://api.seudominio.com

# ──────────────────────────────────────────
# PgAdmin (Opcional - perfil debug)
# ──────────────────────────────────────────
PGADMIN_EMAIL=admin@laboure.com
PGADMIN_PASSWORD=admin123

# ──────────────────────────────────────────
# SMTP (Email - para notificações)
# ──────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha
# SMTP_FROM=noreply@laboure.com

# ──────────────────────────────────────────
# PAYMENT GATEWAYS (Opcional)
# ──────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxx

# ──────────────────────────────────────────
# REDIS (Cache - Opcional)
# ──────────────────────────────────────────
# REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=

# ──────────────────────────────────────────
# STORAGE (AWS S3 ou similar - Opcional)
# ──────────────────────────────────────────
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# AWS_REGION=sa-east-1
# AWS_S3_BUCKET=laboure-images

# ──────────────────────────────────────────
# SECURITY
# ──────────────────────────────────────────
# CORS_ORIGINS=http://localhost:3000,https://seudominio.com
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ──────────────────────────────────────────
# LOGGING
# ──────────────────────────────────────────
# LOG_LEVEL=info
# Options: error, warn, info, http, verbose, debug, silly